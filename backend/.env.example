OKAK_APP__NAME=ОКАК API
OKAK_APP__VERSION=0.1.0
OKAK_APP__CORS_ORIGINS=["http://localhost:3000"]

OKAK_POSTGRES__HOST=localhost
OKAK_POSTGRES__PORT=5432
